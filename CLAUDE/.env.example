# drug_discovery_pipeline/.env.example
# =============================================================================
# FILE: .env.example
# DESCRIPTION: Example environment variable configuration for the drug discovery pipeline.
# =============================================================================

# ── Ollama servers ────────────────────────────────────────────────────────────
LOCAL_OLLAMA_URL=http://localhost:11434/v1
REMOTE_OLLAMA_URL=http://REPLACE_WITH_REMOTE_HOST:11434/v1

# ── Model overrides (uncomment to override config.py defaults) ────────────────
# LLM_MODEL=gemma4:31b-it-q8_0
# LOCAL_BIO_MODEL=medgemma1.5:latest
# LOCAL_CODE_MODEL=deepseek-coder:6.7b
# LOCAL_FALLBACK_MODEL=mistral:7b
# EMBEDDING_MODEL=nomic-embed-text

# ── Docking ───────────────────────────────────────────────────────────────────
VINA_PATH=vina
RECEPTOR_PDBQT=

# ── External API keys ─────────────────────────────────────────────────────────
NCBI_API_KEY=
PATENTSVIEW_API_KEY=

# ── Behaviour ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# NUM_CANDIDATES_GENERATE=20
# NUM_CANDIDATES_SHORTLIST=5
# LLM_TIMEOUT=360
# LLM_RETRIES=3
# LLM_RETRY_DELAY=8.0

# ── Directory overrides ───────────────────────────────────────────────────────
# OUTPUT_DIR=/data/drug_discovery/outputs
# CHROMA_DIR=/data/drug_discovery/chroma_db
# WORK_DIR=/tmp/drug_discovery_workdir